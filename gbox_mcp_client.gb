class GBoxMCP:GSocketUdp{
	void Start(int port){
		BindPort(port);
		?"Gbox Mcp Client UDP started at "+sys::GetSelfIPAddress()+":"+m_nPort;
	}
	void OnCmd(int cmd,var agv,int ip,int port){
		SendTo(ip, port, 1, "本MCP为游戏《AIWorld》的控制器。这是一个AI驱动的开放世界游戏，玩家可以探索动态生成的环境并与智能NPC互动");
		?"agv:  ",agv;
		/*
		if(!agv.IsString()){
			?"on cmd err:",cmd,agv,ip,port;
			return;
		}
		var result;string s;
		var msg =agv.JsonToStrVal();
		string funname=msg.svVal("function","");
		if(funname.length>0){
			var callagv;
			if(!CallByNameWithRet(funname,callagv)){
				result.svSet("error","call function fail");
			}else{
				result.svSet("result",callagv);
			}
		}else{
			result.svSet("error","agv format err:no function");
		}
		if(result.svGetJsonText(s)) SendTo(ip, port, 1, s);
		else SendTo(ip, port, 1, ""+result);
		?"cmd:"+cmd+";agv:"+agv+";ip:"+ip+";port:"+port+";result="+result;
		*/
	}
	string get_mcp_description(){
		return "本MCP为游戏《AIWorld》的控制器。这是一个AI驱动的开放世界游戏，玩家可以探索动态生成的环境并与智能NPC互动";
	}
	string get_tools(){
		var v,vfun;string result;
		vfun.svSet("name","get_scene_range");
		vfun.svSet("description","获取场景地图的尺寸范围,返回(xmin,ymin,xmax,ymax)");
		vfun.svSet("function","get_scene_range");
		v.svSet("get_scene_range",vfun);
		vfun.svSet("name","create_rand_object");
		vfun.svSet("description","在场景中的随机位置创建一个随机物体");
		vfun.svSet("function","create_rand_object");
		v.svSet("create_rand_object",vfun);
		if(!v.svGetJsonText(result)){
			Err("转换结果失败:"+v);	
		}
		return result;
	}
	string get_scene_range(){
		return "[-25,-25,25,25]";
	}
	string create_rand_object(){
		return "创建了一个随机物体";
	}
}
// 只需要一个UDP实例来监听
GBoxMCP m_pOut:Start(20000);s