class SysBoxMCP:GSocketUdp{
	obj m_pTool;
	void Start(int port){
		BindPort(port);
		?"Gbox Mcp Client UDP started at "+sys::GetSelfIPAddress()+":"+m_nPort;
	}
	void RegTool(obj p){
		m_pTool=p;
	}
	void OnCmd(int cmd,var agv,int ip,int port){
		if(!agv.IsString()){
			?"on cmd err:",cmd,agv,ip,port;
			return;
		}
		var result;string s;
		var msg =agv.JsonToStrVal();
		string funname=msg.svVal("function","");
		if(funname.length>0){
			var callagv;
			if(!CallByNameWithRet(funname,callagv)){
				result.svSet("error","call function fail");
			}else{
				result.svSet("result",callagv);
			}
		}else{
			result.svSet("error","agv format err:no function");
		}
		if(result.svGetJsonText(s)) SendTo(ip, port, 1, s);
		else SendTo(ip, port, 1, ""+result);
		?"cmd:"+cmd+";agv:"+agv+";ip:"+ip+";port:"+port+";result="+result;
	}
	var get_tools(){
		var v=GLLM::GetTools(m_pTool);
		?v;
		return v;
	}
}
class GMcpTool:GObj{
	obj get_obj_by_uid(int64 uid){
		return m_pScene;
	}
	notes("fun","获取场景树根节点=get_scene_root_info","","","","获取场景树根节点信息");
	var get_scene_root_info(){
		var v;
		v.svSet("uid",""+m_pScene);
		v.svSet("name",m_pScene.GetName());
		return v;
	}
	notes("fun","获取子节点=get_sub_node_list_info","对象uid=0","","","获取某节点的子节点列表");
	var get_sub_node_list_info(int64 uid=0){
		var v,ret;
		obj p=get_obj_by_uid(uid);
		if(!p.isobj()){
			ERR::Str("没找到uid对象;uid="+uid);
			return v;
		}
		obj psub;
		var szsub=p.GetAllSubSz();
		for psub in szsub{
			v.svSet("uid",""+psub);
			v.svSet("name",m_pScene.GetName());
			ret.SzAdd(v);
		}
		return ret;
	}
}

#ifmain "def.gb"
GMcpTool m_pTool;
// 只需要一个UDP实例来监听
SysBoxMCP m_pMcp:Start(20000):RegTool(m_pTool);

?m_pMcp.get_tools();
#endif
